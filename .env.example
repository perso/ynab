YNAB_BUDGET_ID='your-budget-uuid-here'

# Optional: set to 'true' to upload transactions directly to YNAB via the API,
# skipping the manual CSV import step. Requires budget_id and account_id to be
# set in accounts.toml. Output CSVs are still written.
# YNAB_UPLOAD_ENABLED=true

# Optional: set to 'true' to filter out transactions already in YNAB before
# writing output. Requires budget_id and account_id to be set in accounts.toml.
# Recommended when YNAB_UPLOAD_ENABLED=true to prevent re-importing transactions
# that were entered manually in YNAB.
# YNAB_DEDUP_ENABLED=true

# Optional: override the default path to accounts.toml.
# YNAB_ACCOUNTS_CONFIG=/path/to/accounts.toml
