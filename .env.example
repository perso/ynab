YNAB_BUDGET_ID='your-budget-uuid-here'

# Optional: set to 'true' to filter out transactions already in YNAB.
# Requires budget_id and account_id to be set in accounts.toml.
# YNAB_DEDUP_ENABLED=true

# Optional: override the default path to accounts.toml.
# YNAB_ACCOUNTS_CONFIG=/path/to/accounts.toml